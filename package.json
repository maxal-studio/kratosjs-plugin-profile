{
  "name": "@maxal_studio/kratosjs-plugin-profile",
  "version": "2.0.0",
  "description": "User profile page (edit details + change password) for KratosJs panels",
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.server.json && tsc -p tsconfig.client.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "kratosjs",
    "kratosjs-plugin"
  ],
  "author": "MaxAl",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0"
  },
  "peerDependencies": {
    "@maxal_studio/kratosjs-react": "^2.0.0",
    "@maxal_studio/kratosjs": "^2.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/react": "^19.2.5",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/maxal-studio/kratosjs-plugin-profile.git"
  },
  "bugs": {
    "url": "https://github.com/maxal-studio/kratosjs-plugin-profile/issues"
  },
  "homepage": "https://github.com/maxal-studio/kratosjs-plugin-profile#readme"
}
